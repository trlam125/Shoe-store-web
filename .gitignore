# ============================================================
# LSHOE Store - Git ignore rules
# Spring Boot (Maven) + Python AI services + PostgreSQL
# ============================================================

# ---------- Secrets and environment-specific configuration ----------
.env
.env.*
!*.env.example
!*.env.template
!**/.env.example
!**/.env.template

# Local Spring configuration that may contain credentials
application-local.properties
application-secrets.properties
application-*.local.properties
**/application-local.properties
**/application-secrets.properties
**/application-*.local.properties

# Private keys, certificates and tokens
*.pem
*.key
*.p12
*.pfx
*.jks
*.keystore
*.crt
*.cer
secrets/
**/secrets/

# ---------- Java / Maven ----------
target/
**/target/
build/
**/build/
out/
**/out/
*.class
*.jar.original
dependency-reduced-pom.xml
.flattened-pom.xml
.mvn/timing.properties

# JVM crash and diagnostic files
hs_err_pid*
replay_pid*
.attach_pid*
*.hprof

# ---------- Python ----------
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
*.pyd
*.so
.Python
.python-version

# Virtual environments
.venv/
venv/
env/
ENV/
**/.venv/
**/venv/
**/env/
**/ENV/

