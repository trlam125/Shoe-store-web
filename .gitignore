# ============================================================================
# LSHOE Store
# Spring Boot (Maven) + Python AI service + PostgreSQL
# ============================================================================

# ----------------------------------------------------------------------------
# Secrets and machine-specific configuration
# ----------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.template
!**/.env.example
!**/.env.template

# Local Spring profiles/configuration that may contain credentials
application-local.properties
application-secrets.properties
application-*.local.properties

# Credentials, private keys and local secret directories
*.key
*.pem
*.p12
*.pfx
*.jks
*.keystore
credentials*.json
service-account*.json
secrets/

# ----------------------------------------------------------------------------
# Java / Maven
# ----------------------------------------------------------------------------
target/
build/
out/
*.class
*.jar.original
dependency-reduced-pom.xml
.flattened-pom.xml
.mvn/timing.properties

# JVM crash and diagnostic files
hs_err_pid*
replay_pid*
.attach_pid*
*.hprof

# ----------------------------------------------------------------------------
# Python
# ----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyd
*.so
.Python

# Virtual environments
.venv/
venv/
env/
ENV/

# Packaging/build output
dist/
.eggs/
*.egg
*.egg-info/
pip-wheel-metadata/
wheels/

