# ==========================================================
# LSHOE shared configuration
# File location: D:/Lshoe-store/.env (next to pom.xml)
# ==========================================================

# IntelliJ/Spring project root. Use forward slashes on Windows.
LSHOE_PROJECT_ROOT=D:/Lshoe-store

# Spring Boot
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8081
SESSION_TIMEOUT=12h

# PostgreSQL for Spring Boot
DATABASE_URL=jdbc:postgresql://127.0.0.1:5432/lshoe_store
DB_USERNAME=postgres
DB_PASSWORD=

# PostgreSQL for Python AI service.
# Repeat the same username/password here. If the password contains special
# URL characters such as @, :, /, # or %, URL-encode the password first.
AI_DATABASE_URL=postgresql://postgres:password@127.0.0.1:5432/lshoe_store

# FastAPI AI service
AI_SERVICE_URL=http://127.0.0.1:8001
AI_SERVICE_AUTOSTART=true
AI_SERVICE_SETUP_VENV=true
AI_SERVICE_AUTOSTART_TIMEOUT_SECONDS=60
AI_IMAGE_TIMEOUT_MS=120000
AI_ALLOWED_ORIGINS=http://localhost:8081,http://127.0.0.1:8081
AI_STORE_BASE_URL=http://127.0.0.1:8081

# Optional shared secret between Spring Boot and the AI service.
# Leave both sides empty for local-only access, or set a long random value.
AI_INTERNAL_API_KEY=whyalwaysme

# Embedded chatbot in the main website (no Streamlit)
NVIDIA_API_KEY=api_key
CHATBOT_API_URL=https://integrate.api.nvidia.com/v1/chat/completions
CHATBOT_MODEL=openai/gpt-oss-120b
CHATBOT_TIMEOUT_MS=30000
CHATBOT_MAX_TOKENS=4096
CHATBOT_EMPTY_RESPONSE_RETRIES=1
CHATBOT_CATALOG_MAX_CHARACTERS=40000

# Optional mail configuration for password reset
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=user1
MAIL_PASSWORD=0123
MAIL_SMTP_AUTH=true
MAIL_STARTTLS=true

# Optional application settings
APP_PUBLIC_BASE_URL=http://localhost:8081
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
SEED_DEMO_DATA=false
PASSWORD_RESET_EXPIRY_MINUTES=30
PASSWORD_RESET_LOG_LINK=true
CHAT_RATE_LIMIT_PER_MINUTE=20
IMAGE_RATE_LIMIT_PER_MINUTE=5
PASSWORD_RESET_RATE_LIMIT_PER_15_MINUTES=3
TRUST_PROXY_HEADERS=true
SESSION_COOKIE_SECURE=false

# true: Run Current File starts Cloudflare after localhost:8081 is reachable.
# false: web and ai-service remain local only.
CLOUDFLARE_TUNNEL_AUTOSTART=true

# quick = temporary random https://*.trycloudflare.com URL
# named = stable hostname configured in cloudflared-config.yml
CLOUDFLARE_TUNNEL_MODE=quick

# cloudflared executable, relative to the project root or an absolute path.
CLOUDFLARE_TUNNEL_EXECUTABLE=cloudflared-windows-amd64.exe

# Local Spring Boot origin to publish.
CLOUDFLARE_TUNNEL_LOCAL_URL=http://127.0.0.1:8081
CLOUDFLARE_TUNNEL_STARTUP_TIMEOUT_SECONDS=45

# Used only when CLOUDFLARE_TUNNEL_MODE=named
CLOUDFLARE_TUNNEL_CONFIG=cloudflared-config.yml
CLOUDFLARE_TUNNEL_NAME=lshoe-store

# Recommended when requests pass through Cloudflare/reverse proxies.
SERVER_FORWARD_HEADERS_STRATEGY=framework
