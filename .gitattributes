# Chuẩn hoá line endings: Windows checkout CRLF, commit LF
* text=auto

# Java / XML / Properties — luôn dùng LF
*.java    text eol=lf
*.xml     text eol=lf
*.properties text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf
*.html    text eol=lf
*.css     text eol=lf
*.js      text eol=lf
*.md      text eol=lf
*.sql     text eol=lf

# Binary — không sờ vào line endings
*.jar     binary
*.class   binary
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.ico     binary
*.woff    binary
*.woff2   binary
*.ttf     binary
*.eot     binary
