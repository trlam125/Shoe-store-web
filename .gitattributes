# ============================================================
# LSHOE Store - Git attributes
# Normalize text files while keeping platform scripts usable.
# ============================================================

# Let Git detect text files and store them with LF in the repository.
* text=auto eol=lf

# ---------- Platform-specific scripts ----------
# Windows command scripts are checked out with CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Unix shell scripts must keep LF.
*.sh text eol=lf

# ---------- Source code ----------
*.java text eol=lf diff=java
*.kt text eol=lf
*.kts text eol=lf
*.py text eol=lf diff=python
*.js text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.ts text eol=lf
*.tsx text eol=lf

# ---------- Web templates and styles ----------
*.html text eol=lf
*.htm text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.sass text eol=lf
*.less text eol=lf
*.svg text eol=lf

# ---------- Configuration, data and documentation ----------
*.xml text eol=lf
*.properties text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.conf text eol=lf
*.sql text eol=lf
*.csv text eol=lf
*.tsv text eol=lf
*.md text eol=lf diff=markdown
*.txt text eol=lf
*.env text eol=lf
*.env.* text eol=lf

pom.xml text eol=lf
docker-compose.yml text eol=lf
docker-compose.yaml text eol=lf
Dockerfile text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf

