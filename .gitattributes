# Normalize text files to LF in the repository by default.
* text=auto eol=lf

# Keep Windows scripts in CRLF so they run cleanly in cmd/PowerShell.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Source files
*.java text eol=lf diff=java
*.kt text eol=lf
*.xml text eol=lf
*.properties text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sql text eol=lf
*.py text eol=lf diff=python
*.sh text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.md text eol=lf diff=markdown
*.gitignore text eol=lf
*.gitattributes text eol=lf

# Binary assets
*.jar binary
*.war binary
*.ear binary
*.class binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.eot binary
*.zip binary
*.tar binary
*.gz binary
*.7z binary
*.pt binary
*.pth binary
*.ckpt binary
*.onnx binary
